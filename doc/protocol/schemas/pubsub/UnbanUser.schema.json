{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voiceroom.example/protocol/pubsub/UnbanUser",
  "title": "UnbanUser",
  "description": "Redis Pub/Sub: 解除封禁事件，channel=admin:events",
  "type": "object",
  "required": ["type", "payload", "admin_id", "ts"],
  "additionalProperties": false,
  "properties": {
    "type": { "type": "string", "const": "unban_user" },
    "payload": {
      "type": "object",
      "required": ["user_id"],
      "additionalProperties": false,
      "properties": {
        "user_id": { "type": "string", "format": "uuid", "description": "被解封的用户 ID" }
      }
    },
    "admin_id": { "type": "string", "format": "uuid", "description": "执行操作的管理员 ID" },
    "ts": { "type": "integer", "description": "事件时间戳(ms)" }
  }
}
