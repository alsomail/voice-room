# =============================================================================
# E2E profile: staging
# 复制此文件为 tests/scripts/env/.env.staging 并填入真实凭据。
# ⚠️  staging 环境真实凭据严禁提交。该实文件已 gitignored。
# 字段唯一真值源： doc/tds/infra/T-0000F.md §2.3（24 主字段）
# =============================================================================

# --- envLoader 路由 ---
E2E_PROFILE=staging
# ⚠️ staging 默认允许写操作，但仅在显式确认后启用
E2E_ALLOW_WRITES=1

# --- 被测服务地址（占位，使用前请替换为真实域名） ---
APP_SERVER_BASE_URL=https://stg-app.example.com
ADMIN_SERVER_BASE_URL=https://stg-admin.example.com
ADMIN_WEB_URL=https://stg-web.example.com
APP_WS_URL=wss://stg-app.example.com/ws

# --- 数据库 / 缓存（远端 staging 通常不直连，留空；若需断言/seed 由跳板机注入） ---
DATABASE_URL=
REDIS_URL=

# --- Android 应用 ID（staging flavor） ---
ANDROID_APP_ID=com.voiceroom.stg

# --- C 端测试 token（⚠️ 请填真实 staging 颁发的占位 token） ---
E2E_VALID_TOKEN=
E2E_EXPIRED_TOKEN=

# --- Admin 端测试 token，按角色准备（⚠️ 真实凭据） ---
E2E_ADMIN_TOKEN=
E2E_OP_TOKEN=
E2E_CS_TOKEN=
E2E_FIN_TOKEN=
E2E_EXPIRED_ADMIN_TOKEN=

# --- 测试专用房间 / 用户 ID（staging seed 后回填） ---
E2E_ROOM_ID=
E2E_USER_A_ID=
E2E_USER_B_ID=

# --- Midscene 大模型配置（WEB 用例依赖；CI 由 Secret 注入） ---
MIDSCENE_MODEL_API_KEY=
MIDSCENE_MODEL_NAME=gpt-4o
MIDSCENE_OPENAI_BASE_URL=
MIDSCENE_CACHE=1

# --- CI 软门禁（CI 中置 1） ---
CI_E2E_READY=0
