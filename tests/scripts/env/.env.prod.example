# =============================================================================
# ⚠️⚠️⚠️  E2E profile: prod  ⚠️⚠️⚠️
# 仅 @prod-safe 只读用例可在 prod 环境执行。
# E2E_ALLOW_WRITES 必须保持 0；envLoader (T-0000H) 与 CI 形成五道防线拦截写操作。
# 复制此文件为 tests/scripts/env/.env.prod 并填入真实凭据。该实文件已 gitignored。
# 字段唯一真值源： doc/tds/infra/T-0000F.md §2.3（24 主字段）
# =============================================================================

# --- envLoader 路由 ---
E2E_PROFILE=prod
# ⚠️ prod 写禁止红线 —— 严禁改为 1
E2E_ALLOW_WRITES=0

# --- 被测服务地址（占位，使用前请替换为真实域名） ---
APP_SERVER_BASE_URL=https://app.example.com
ADMIN_SERVER_BASE_URL=https://admin.example.com
ADMIN_WEB_URL=https://web.example.com
APP_WS_URL=wss://app.example.com/ws

# --- 数据库 / 缓存（prod 严禁直连，留空） ---
DATABASE_URL=
REDIS_URL=

# --- Android 应用 ID（prod flavor） ---
ANDROID_APP_ID=com.voiceroom

# --- C 端测试 token（⚠️ prod 真实只读凭据，手填，严禁提交） ---
E2E_VALID_TOKEN=
E2E_EXPIRED_TOKEN=

# --- Admin 端测试 token，按角色准备（⚠️ prod 真实只读凭据） ---
E2E_ADMIN_TOKEN=
E2E_OP_TOKEN=
E2E_CS_TOKEN=
E2E_FIN_TOKEN=
E2E_EXPIRED_ADMIN_TOKEN=

# --- 测试专用房间 / 用户 ID ---
E2E_ROOM_ID=
E2E_USER_A_ID=
E2E_USER_B_ID=

# --- Midscene 大模型配置（CI Secret 注入） ---
MIDSCENE_MODEL_API_KEY=
MIDSCENE_MODEL_NAME=gpt-4o
MIDSCENE_OPENAI_BASE_URL=
MIDSCENE_CACHE=1

# --- CI 软门禁（CI 中置 1） ---
CI_E2E_READY=0
