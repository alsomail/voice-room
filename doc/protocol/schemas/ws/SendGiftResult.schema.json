{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voiceroom.example/protocol/ws/SendGiftResult",
  "title": "SendGiftResult",
  "description": "发礼物结果 (S→C)",
  "type": "object",
  "required": ["type", "msg_id", "code", "timestamp"],
  "additionalProperties": false,
  "properties": {
    "type": { "type": "string", "const": "SendGiftResult" },
    "msg_id": { "type": "string", "format": "uuid" },
    "code": { "type": "integer" },
    "message": { "type": "string" },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "gift_record_id": { "type": "string", "format": "uuid" },
        "total_price": { "type": "integer", "minimum": 0 }
      }
    },
    "timestamp": { "type": "integer" }
  }
}
