# =============================================================================
# E2E profile: local
# 复制此文件为 tests/scripts/env/.env.local 并按需调整。该实文件已 gitignored。
# 字段唯一真值源： doc/tds/infra/T-0000F.md §2.3（24 主字段）
# =============================================================================

# --- envLoader 路由 ---
E2E_PROFILE=local
E2E_ALLOW_WRITES=1

# --- 被测服务地址 ---
APP_SERVER_BASE_URL=http://localhost:3000
ADMIN_SERVER_BASE_URL=http://localhost:3001
ADMIN_WEB_URL=http://localhost:5173
APP_WS_URL=ws://localhost:3000/ws

# --- 数据库 / 缓存（local 直连 docker-compose 起的 PG / Redis） ---
DATABASE_URL=postgres://app_server_user:app_server_pass@localhost:5432/voiceroom
REDIS_URL=redis://localhost:6379

# --- Android 应用 ID（local flavor） ---
ANDROID_APP_ID=com.voiceroom.local

# --- C 端测试 token（seed 回填，24h 寿命） ---
E2E_VALID_TOKEN=
E2E_EXPIRED_TOKEN=

# --- Admin 端测试 token，按角色准备 ---
E2E_ADMIN_TOKEN=
E2E_OP_TOKEN=
E2E_CS_TOKEN=
E2E_FIN_TOKEN=
E2E_EXPIRED_ADMIN_TOKEN=

# --- 测试专用房间 / 用户 ID（Seed 生成后回填） ---
E2E_ROOM_ID=
E2E_USER_A_ID=
E2E_USER_B_ID=

# --- Midscene 大模型配置（WEB 用例依赖；可留空 → WEB 用例 skip） ---
MIDSCENE_MODEL_API_KEY=
MIDSCENE_MODEL_NAME=gpt-4o
MIDSCENE_OPENAI_BASE_URL=
MIDSCENE_CACHE=1

# Midscene AI 视觉断言（WEB E2E 用）
# 三种部署形态任选其一：
# 1. OpenAI 直连（推荐）
#    MIDSCENE_MODEL_API_KEY=sk-proj-xxxxxx  # 从 https://platform.openai.com/api-keys 获取
#
# 2. Azure OpenAI（需同时设置 endpoint + key）
#    AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
#    AZURE_OPENAI_API_KEY=your-azure-key-placeholder
#
# 3. 中转服务（如 one-api）
#    MIDSCENE_MODEL_API_KEY=sk-custom-xxxx
#    MIDSCENE_MODEL_BASE_URL=https://your-proxy.com/v1  # 可选，默认 https://api.openai.com/v1
#
# 注意：
# - local profile 建议使用个人 OpenAI Key（免费额度或自付费）
# - 缺失时 WEB 测试自动 skip，不影响 API/INFRA 测试
# - 真实 Key 严禁提交（已 gitignored）

# --- CI 软门禁 ---
CI_E2E_READY=0
