{
  "name": "voice-room",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "doc": "doc"
  },
  "scripts": {
    "e2e:up": "bash scripts/dev/e2e-up.sh",
    "start": "bash scripts/dev/start-local.sh",
    "stop": "bash scripts/dev/e2e-down.sh",
    "status": "bash scripts/dev/status.sh",
    "e2e:local": "cross-env E2E_PROFILE=local playwright test",
    "e2e:android": "cross-env E2E_PROFILE=local playwright test tests/scripts/AND tests/scripts/E2E",
    "e2e:web": "cross-env E2E_PROFILE=local playwright test tests/scripts/WEB",
    "e2e:staging": "cross-env E2E_PROFILE=staging playwright test",
    "e2e:prod-smoke": "cross-env E2E_PROFILE=prod playwright test --grep \"@prod-safe\"",
    "db:seed": "cross-env E2E_PROFILE=local E2E_ALLOW_WRITES=1 bash scripts/dev/seed-e2e.sh",
    "db:reset": "cross-env E2E_PROFILE=local bash scripts/dev/reset-e2e.sh",
    "preflight": "bash scripts/dev/preflight.sh",
    "audit:protocol": "npx ts-node --project tsconfig.scripts.json scripts/audit/protocol-binding-audit.ts",
    "test:audit": "jest scripts/audit/",
    "audit:fields": "npx ts-node --project tsconfig.scripts.json scripts/audit/protocol-binding-audit.ts --field-level",
    "test:cross-lang:ws": "jest --config jest.cross-lang.config.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alsomail/voice-room.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/alsomail/voice-room/issues"
  },
  "homepage": "https://github.com/alsomail/voice-room#readme",
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@midscene/android": "^1.7.5",
    "@midscene/web": "^1.7.5",
    "@playwright/test": "^1.59.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "cross-env": "^7.0.3",
    "dotenv": "^17.4.2",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
