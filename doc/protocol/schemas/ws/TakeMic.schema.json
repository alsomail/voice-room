{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voiceroom.example/protocol/ws/TakeMic",
  "title": "TakeMic",
  "description": "上麦请求 (C→S)",
  "type": "object",
  "required": ["type", "msg_id", "payload"],
  "additionalProperties": false,
  "properties": {
    "type": { "type": "string", "const": "TakeMic" },
    "msg_id": { "type": "string", "format": "uuid" },
    "payload": {
      "type": "object",
      "required": ["mic_index"],
      "additionalProperties": false,
      "properties": {
        "mic_index": { "type": "integer", "minimum": 0, "maximum": 8, "description": "目标麦位索引 0-8" }
      }
    },
    "timestamp": { "type": "integer" }
  }
}
