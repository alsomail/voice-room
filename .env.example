# =============================================================================
# Voice Room 主 .env 模板
# 复制此文件为 .env 并填入实际值。.env 已在 .gitignore 中。
# Copy this file to .env and fill in actual values. .env is gitignored.
# =============================================================================
#
# 字段总览：
#   1) Docker / Server 启动字段（注释行声明，按需取消注释）
#   2) E2E 测试 24 主字段（与 tests/scripts/env/.env.<profile>.example 严格对齐）
#
# 字段唯一真值源： doc/tds/infra/T-0000F.md §2.3
# 上游契约：       doc/tds/infra/T-0000E.md §2.4.1
# 下游消费方：     T-0000H envLoader（按 E2E_PROFILE 路由）
# =============================================================================


# -----------------------------------------------------------------------------
# 1) Docker / Server 启动字段（不计入 E2E 24 主字段；以注释行声明，避免新人误以为分布在不同文件）
#    docker-compose 已对前 3 个字段提供 `:-default` 兜底；JWT 密钥须显式取消注释并设置真值。
# -----------------------------------------------------------------------------
# POSTGRES_PASSWORD=postgres
# APP_SERVER_PASS=app_server_pass               # 与 scripts/dev/init-db.sh 注入字段名一致
# ADMIN_SERVER_PASS=admin_server_pass
# APP_JWT_SECRET=change-me-in-production        # 与 T-00040 启动校验配合
# ADMIN_JWT_SECRET=change-me-in-production      # 与 T-10020 启动校验配合


# =============================================================================
# 2) E2E 测试 24 主字段（顺序锁住，对 envLoader 单一字段映射表的前提）
#    tests/scripts/env/.env.<profile>.example 必须与本段字段集合一一对齐。
# =============================================================================

# --- envLoader 路由 ---
E2E_PROFILE=local
E2E_ALLOW_WRITES=1

# --- 被测服务地址 ---
APP_SERVER_BASE_URL=http://localhost:3000
ADMIN_SERVER_BASE_URL=http://localhost:3001
ADMIN_WEB_URL=http://localhost:5173
APP_WS_URL=ws://localhost:3000/ws

# --- 数据库 / 缓存（脚本里直接 psql / redis-cli 做前置清理与断言） ---
DATABASE_URL=postgres://app_server_user:app_server_pass@localhost:5432/voice_room
REDIS_URL=redis://localhost:6379

# --- Android 应用 ID（与 T-30050 productFlavors `applicationIdSuffix` 对应） ---
ANDROID_APP_ID=com.voiceroom.local

# --- C 端测试 token（由 scripts/dev/seed-e2e.sql 生成后回填，T-0000G 负责） ---
E2E_VALID_TOKEN=
E2E_EXPIRED_TOKEN=

# --- Admin 端测试 token，按角色准备 ---
E2E_ADMIN_TOKEN=
E2E_OP_TOKEN=
E2E_CS_TOKEN=
E2E_FIN_TOKEN=
E2E_EXPIRED_ADMIN_TOKEN=

# --- 测试专用房间 / 用户 ID（Seed 生成后回填） ---
E2E_ROOM_ID=
E2E_USER_A_ID=
E2E_USER_B_ID=

# --- Midscene 大模型配置（WEB 用例依赖；缺则 WEB 用例 skip，详见 T-0000K） ---
MIDSCENE_MODEL_API_KEY=
MIDSCENE_MODEL_NAME=gpt-4o
MIDSCENE_OPENAI_BASE_URL=
MIDSCENE_CACHE=1

# --- CI 软门禁（CI 默认 0；为 1 时 tests/scripts/** 才真正跑） ---
CI_E2E_READY=0


# -----------------------------------------------------------------------------
# 附：跨端字段提示（不在本文件声明 KEY=VALUE，仅注释提示，避免被 envLoader 误读）
# -----------------------------------------------------------------------------
# Web (Vite): VITE_ADMIN_API_BASE_URL / VITE_API_BASE_URL / VITE_WS_URL / VITE_ANALYTICS_ENDPOINT
#   缺陷 3 修复（batch-e2e-foundation-01 第 1 轮）：VITE_* 在 Vite 构建时由
#   `app/web/vite.config.ts` 的 loadEnv + define 从本根 env 自动注入，
#   无需独立维护 `app/web/.env.*`（已清空 URL 字段，仅保留 web 独有 K=V）。
# Android (Gradle): VOICE_ROOM_API_BASE_URL / VOICE_ROOM_WS_URL / VOICE_ROOM_ANALYTICS_ENDPOINT
#   由 `tests/scripts/support/envLoader.writeProcessEnv` 自动桥接 process.env，
#   gradlew 通过 `resolveConfigValue(localProperties, ..., env, default)` 读取注入 BuildConfig。
