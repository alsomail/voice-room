{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voiceroom.example/protocol/ws/LeaveMic",
  "title": "LeaveMic",
  "description": "下麦请求 (C→S)",
  "type": "object",
  "required": ["type", "msg_id"],
  "additionalProperties": false,
  "properties": {
    "type": { "type": "string", "const": "LeaveMic" },
    "msg_id": { "type": "string", "format": "uuid" },
    "payload": {
      "type": "object",
      "properties": {
        "mic_index": {
          "type": "integer",
          "description": "可选；客户端发送用于调试/日志追踪，服务端通过连接上下文推断槽位，不读取此字段"
        }
      },
      "additionalProperties": true
    },
    "timestamp": { "type": "integer" }
  }
}
