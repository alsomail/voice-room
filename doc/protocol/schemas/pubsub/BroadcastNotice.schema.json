{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voiceroom.example/protocol/pubsub/BroadcastNotice",
  "title": "BroadcastNotice",
  "description": "Redis Pub/Sub: 全局公告广播事件，channel=admin:events",
  "type": "object",
  "required": ["type", "payload", "admin_id", "ts"],
  "additionalProperties": false,
  "properties": {
    "type": { "type": "string", "const": "broadcast_notice" },
    "payload": {
      "type": "object",
      "required": ["message"],
      "additionalProperties": false,
      "properties": {
        "message": { "type": "string", "minLength": 1, "description": "公告内容" }
      }
    },
    "admin_id": { "type": "string", "format": "uuid", "description": "执行操作的管理员 ID" },
    "ts": { "type": "integer", "description": "事件时间戳(ms)" }
  }
}
