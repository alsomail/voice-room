# 复制此文件为 .env 并填入实际值，.env 已在 .gitignore 中
# Copy this file to .env and fill in actual values. .env is gitignored.

# PostgreSQL
POSTGRES_PASSWORD=postgres

# 应用账号密码（docker-compose 启动时注入至 init-db.sh）
APP_SERVER_PASS=app_server_pass
ADMIN_SERVER_PASS=admin_server_pass

# JWT 密钥（Server 和 AdminServer 各自配置，不共用）
APP_JWT_SECRET=change-me-in-production
ADMIN_JWT_SECRET=change-me-in-production

# ============================================================
# E2E 测试相关（tests/scripts/** 读取）
# ============================================================
# 被测服务地址
APP_SERVER_BASE_URL=http://localhost:3000
ADMIN_SERVER_BASE_URL=http://localhost:3001
ADMIN_WEB_URL=http://localhost:5173
APP_WS_URL=ws://localhost:3000/ws

# 连接 App Server 使用的测试库（脚本里直接 psql / redis-cli 做前置清理与断言）
DATABASE_URL=postgres://app_server_user:app_server_pass@localhost:5432/voice_room
REDIS_URL=redis://localhost:6379

# Android 应用
ANDROID_APP_ID=com.voiceroom.debug

# 预置测试账号（由 scripts/dev/seed-e2e.sql 生成，尚未编写）
# —— C 端
E2E_VALID_TOKEN=
E2E_EXPIRED_TOKEN=
# —— Admin 端，按角色准备
E2E_ADMIN_TOKEN=
E2E_OP_TOKEN=
E2E_CS_TOKEN=
E2E_FIN_TOKEN=
E2E_EXPIRED_ADMIN_TOKEN=

# 测试专用房间 / 用户 ID（Seed 生成后回填）
E2E_ROOM_ID=
E2E_USER_A_ID=
E2E_USER_B_ID=

# Midscene 大模型配置（WEB 用例依赖）
MIDSCENE_MODEL_API_KEY=
MIDSCENE_MODEL_NAME=gpt-4o
MIDSCENE_OPENAI_BASE_URL=
MIDSCENE_CACHE=1

# 触发实际执行 E2E（CI 默认 0；为 1 时 tests/scripts/** 才真正跑）
CI_E2E_READY=0
