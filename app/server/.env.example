# AppServer 启动 ENV 模板（T-00040 §2.3 ENV 字段冻结）
# Profile 入口：APP_PROFILE 主入口，APP_ENV 为向后兼容别名
APP_PROFILE=dev
# APP_ENV=dev   # 旧名（向后兼容，建议使用 APP_PROFILE）

# ── 必填敏感字段（永不写入 toml）
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/voice_room
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=replace-me-with-a-long-random-secret

# ── 第三方
AGORA_APP_CERT=replace-me

# ── 配置目录（可选）
APP_CONFIG_DIR=./config

# ── 非敏感 override（env 优先级最高）
APP__SERVER__HOST=0.0.0.0
APP__SERVER__PORT=3000
APP__LOG__LEVEL=info
APP__LOG__FORMAT=json
# APP__JWT__EXPIRE_SECS=86400
# APP__DATABASE__MAX_CONNECTIONS=10
# APP__DATABASE__CONNECT_TIMEOUT_SECS=5
